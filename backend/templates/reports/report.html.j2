<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>竞品情报报告 - {{ feed.project.project_name }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            max-width: 820px;
            margin: 0 auto;
            padding: 40px 32px;
            color: #333;
            background: #fff;
            line-height: 1.6;
        }

        /* 标题区 */
        .report-header {
            border-left: 4px solid #2c3e50;
            padding-left: 16px;
            margin-bottom: 24px;
        }
        .report-header h1 {
            font-size: 24px;
            color: #1a1a1a;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        /* 元信息区 */
        .meta-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 0;
            border-top: 1px solid #e0e0e0;
            border-bottom: 1px solid #e0e0e0;
            padding: 12px 0;
            margin-bottom: 32px;
        }
        .meta-item {
            flex: 1;
            min-width: 200px;
            padding: 0 16px;
            border-right: 1px solid #e8e8e8;
        }
        .meta-item:last-child { border-right: none; }
        .meta-item:first-child { padding-left: 0; }
        .meta-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .meta-value {
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }
        .status-badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 600;
            background: #e8f5e9;
            color: #2e7d32;
        }

        /* 正文区 */
        .section {
            margin-bottom: 28px;
        }
        .section-title {
            font-size: 16px;
            color: #2c3e50;
            font-weight: 600;
            border-left: 3px solid #3498db;
            padding-left: 12px;
            margin-bottom: 12px;
            line-height: 1.4;
        }
        .section-content {
            font-size: 14px;
            color: #333;
            line-height: 1.8;
            white-space: pre-wrap;
            padding-left: 15px;
        }

        /* 证据 Diff 区 */
        .evidence {
            background: #f8f9fa;
            border-left: 3px solid #e74c3c;
            padding: 16px 16px 16px 19px;
            border-radius: 0 4px 4px 0;
            font-family: "SF Mono", "Fira Code", "Consolas", monospace;
            font-size: 13px;
            line-height: 1.7;
            color: #555;
            white-space: pre-wrap;
            overflow-x: auto;
        }

        /* 底部 */
        .report-footer {
            margin-top: 40px;
            padding-top: 16px;
            border-top: 1px solid #e0e0e0;
            font-size: 12px;
            color: #999;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="report-header">
        <h1>竞品情报报告</h1>
    </div>

    <div class="meta-bar">
        <div class="meta-item">
            <div class="meta-label">项目</div>
            <div class="meta-value">{{ feed.project.project_name }}</div>
        </div>
        <div class="meta-item">
            <div class="meta-label">生成时间</div>
            <div class="meta-value">{{ feed.published_at.strftime("%Y-%m-%d %H:%M") }}</div>
        </div>
        <div class="meta-item">
            <div class="meta-label">状态</div>
            <div class="meta-value"><span class="status-badge">{{ feed.job_status }}</span></div>
        </div>
    </div>

    <div class="section">
        <div class="section-title">变化摘要</div>
        <div class="section-content">{{ feed.change_summary }}</div>
    </div>

    <div class="section">
        <div class="section-title">战略意图</div>
        <div class="section-content">{{ feed.strategic_intent }}</div>
    </div>

    <div class="section">
        <div class="section-title">行动建议</div>
        <div class="section-content">{{ feed.action_suggestion }}</div>
    </div>

    <div class="section">
        <div class="section-title">证据 Diff</div>
        <div class="evidence">{{ feed.evidence_diff }}</div>
    </div>

    <div class="report-footer">
        本报告由竞争情报监控系统自动生成 · {{ feed.published_at.strftime("%Y-%m-%d %H:%M") }}
    </div>
</body>
</html>

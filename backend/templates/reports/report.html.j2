<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>竞品情报报告 - {{ feed.project.project_name }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            max-width: 960px;
            margin: 0 auto;
            padding: 40px 32px;
            color: #333;
            background: #fff;
            line-height: 1.6;
        }

        /* 标题区 */
        .report-header {
            border-left: 4px solid #2c3e50;
            padding-left: 16px;
            margin-bottom: 24px;
        }
        .report-header h1 {
            font-size: 24px;
            color: #1a1a1a;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        /* 元信息区 */
        .meta-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 0;
            border-top: 1px solid #e0e0e0;
            border-bottom: 1px solid #e0e0e0;
            padding: 12px 0;
            margin-bottom: 32px;
        }
        .meta-item {
            flex: 1;
            min-width: 200px;
            padding: 0 16px;
            border-right: 1px solid #e8e8e8;
        }
        .meta-item:last-child { border-right: none; }
        .meta-item:first-child { padding-left: 0; }
        .meta-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .meta-value {
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }
        .status-badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 600;
            background: #e8f5e9;
            color: #2e7d32;
        }

        /* 正文区 */
        .section {
            margin-bottom: 28px;
        }
        .section-title {
            font-size: 16px;
            color: #2c3e50;
            font-weight: 600;
            border-left: 3px solid #3498db;
            padding-left: 12px;
            margin-bottom: 12px;
            line-height: 1.4;
        }
        .section-content {
            font-size: 14px;
            color: #333;
            line-height: 1.8;
            white-space: pre-wrap;
            padding-left: 15px;
        }

        /* LLM 标注的证据区 */
        .evidence-annotated {
            background: #fffbf0;
            border: 1px solid #f0e0a0;
            border-radius: 4px;
            padding: 16px;
            margin-bottom: 16px;
            font-size: 13px;
            color: #666;
            line-height: 1.7;
            white-space: pre-wrap;
        }
        .evidence-annotated-title {
            font-size: 13px;
            font-weight: 600;
            color: #8a6d3b;
            margin-bottom: 8px;
        }

        /* === Git 风格 Diff 对比区 === */
        .diff-container {
            border: 1px solid #d0d7de;
            border-radius: 6px;
            overflow: hidden;
            margin-bottom: 16px;
        }
        .diff-header {
            background: #f6f8fa;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #57606a;
            border-bottom: 1px solid #d0d7de;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .diff-stats {
            font-size: 12px;
            font-weight: 400;
        }
        .diff-stats .added { color: #1a7f37; }
        .diff-stats .removed { color: #d1242f; }
        .diff-stats .ctx-count { color: #8c959f; }

        .diff-table {
            width: 100%;
            border-collapse: collapse;
            font-family: "SF Mono", "Fira Code", "Consolas", "Monaco", monospace;
            font-size: 13px;
            line-height: 1.6;
        }
        .diff-table td {
            padding: 0;
            vertical-align: top;
            border: none;
        }

        /* 行号列 */
        .diff-table .line-num {
            width: 44px;
            min-width: 44px;
            max-width: 44px;
            text-align: right;
            padding: 2px 8px 2px 12px;
            color: #8c959f;
            background: #f6f8fa;
            border-right: 1px solid #d0d7de;
            user-select: none;
            font-size: 11px;
        }

        /* 配对行（左右对比） */
        .diff-pair {
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-bottom: 1px solid #e1e4e8;
        }
        .diff-pair-side {
            padding: 2px 10px 2px 12px;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: "SF Mono", "Fira Code", "Consolas", "Monaco", monospace;
            font-size: 13px;
            line-height: 1.6;
        }
        .diff-pair-side.old {
            background: #ffebe9;
            border-right: 1px solid #d0d7de;
        }
        .diff-pair-side.old::before {
            content: "-";
            color: #d1242f;
            font-weight: 700;
            margin-right: 6px;
        }
        .diff-pair-side.new {
            background: #dafbe1;
        }
        .diff-pair-side.new::before {
            content: "+";
            color: #1a7f37;
            font-weight: 700;
            margin-right: 6px;
        }
        .diff-pair-side.empty {
            background: #f6f8fa;
        }
        .diff-pair-side.empty::before {
            content: "";
        }
        .line-num-inline {
            display: inline-block;
            width: 28px;
            text-align: right;
            color: #8c959f;
            font-size: 11px;
            margin-right: 8px;
            user-select: none;
        }

        /* 新增行（全宽绿色） */
        .diff-row-add {
            background: #dafbe1;
        }
        .diff-row-add .line-content {
            padding: 2px 10px 2px 12px;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .diff-row-add .line-content::before {
            content: "+";
            color: #1a7f37;
            font-weight: 700;
            margin-right: 6px;
        }

        /* 删除行（全宽红色） */
        .diff-row-del {
            background: #ffebe9;
        }
        .diff-row-del .line-content {
            padding: 2px 10px 2px 12px;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .diff-row-del .line-content::before {
            content: "-";
            color: #d1242f;
            font-weight: 700;
            margin-right: 6px;
        }

        /* 上下文行（灰色） */
        .diff-row-ctx {
            background: #f6f8fa;
        }
        .diff-row-ctx .line-content {
            padding: 2px 10px 2px 12px;
            white-space: pre-wrap;
            word-break: break-word;
            color: #57606a;
        }

        /* Hunk 头 */
        .diff-row-hunk {
            background: #ddf4ff;
            border-top: 1px solid #d0d7de;
            border-bottom: 1px solid #d0d7de;
        }
        .diff-row-hunk .line-content {
            padding: 4px 10px 4px 12px;
            color: #0969da;
            font-size: 12px;
            white-space: pre-wrap;
        }

        .diff-content-cell {
            width: calc(100% - 44px);
        }

        /* 底部 */
        .report-footer {
            margin-top: 40px;
            padding-top: 16px;
            border-top: 1px solid #e0e0e0;
            font-size: 12px;
            color: #999;
            text-align: center;
        }

        /* 截断标记 */
        .diff-truncate {
            text-align: center;
            padding: 8px;
            background: #f6f8fa;
            color: #8c959f;
            font-size: 12px;
            font-style: italic;
            border-top: 1px solid #d0d7de;
            border-bottom: 1px solid #d0d7de;
        }
    </style>
</head>
<body>
    <div class="report-header">
        <h1>竞品情报报告</h1>
    </div>

    <div class="meta-bar">
        <div class="meta-item">
            <div class="meta-label">项目</div>
            <div class="meta-value">{{ feed.project.project_name }}</div>
        </div>
        <div class="meta-item">
            <div class="meta-label">生成时间</div>
            <div class="meta-value">{{ feed.published_at.strftime("%Y-%m-%d %H:%M") }}</div>
        </div>
        <div class="meta-item">
            <div class="meta-label">状态</div>
            <div class="meta-value"><span class="status-badge">{{ feed.job_status }}</span></div>
        </div>
    </div>

    <div class="section">
        <div class="section-title">竞品概述</div>
        <div class="section-content">{{ feed.competitor_overview }}</div>
    </div>

    <div class="section">
        <div class="section-title">变化摘要</div>
        <div class="section-content">{{ feed.change_summary }}</div>
    </div>

    <div class="section">
        <div class="section-title">战略意图</div>
        <div class="section-content">{{ feed.strategic_intent }}</div>
    </div>

    <div class="section">
        <div class="section-title">行动建议</div>
        <div class="section-content">{{ feed.action_suggestion }}</div>
    </div>

    <div class="section">
        <div class="section-title">证据对比</div>

        {% if feed.evidence_diff %}
        <div class="evidence-annotated">
            <div class="evidence-annotated-title">LLM 标注的关键证据</div>
            {{ feed.evidence_diff }}
        </div>
        {% endif %}

        {% set diff_lines = feed.diff_text | parse_diff %}
        {% if diff_lines %}
        <div class="diff-container">
            <div class="diff-header">
                完整内容差异对比
                {% set additions = diff_lines | selectattr("type", "equalto", "add") | list %}
                {% set deletions = diff_lines | selectattr("type", "equalto", "del") | list %}
                {% set pairs = diff_lines | selectattr("type", "equalto", "pair") | list %}
                {% set ctxs = diff_lines | selectattr("type", "equalto", "ctx") | list %}
                <span class="diff-stats">
                    <span class="added">+{{ additions | length + pairs | length }}</span>
                    <span class="removed">-{{ deletions | length + pairs | length }}</span>
                    <span class="ctx-count">{{ ctxs | length }} context</span>
                </span>
            </div>
            <div class="diff-body">
                {% set old_line = namespace(val=0) %}
                {% set new_line = namespace(val=0) %}
                {% for item in diff_lines %}
                    {% if item.type == "hunk" %}
                        <div class="diff-row-hunk">
                            <table class="diff-table">
                                <tr class="diff-row-hunk">
                                    <td class="line-num"></td>
                                    <td class="diff-content-cell">
                                        <div class="line-content">{{ item.content }}</div>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    {% elif item.type == "pair" %}
                        <div class="diff-pair">
                            {% set old_line.val = old_line.val + 1 %}
                            {% set new_line.val = new_line.val + 1 %}
                            <div class="diff-pair-side old">
                                <span class="line-num-inline">{{ old_line.val }}</span>{{ item.old }}
                            </div>
                            <div class="diff-pair-side new">
                                <span class="line-num-inline">{{ new_line.val }}</span>{{ item.new }}
                            </div>
                        </div>
                    {% elif item.type == "add" %}
                        {% set new_line.val = new_line.val + 1 %}
                        <table class="diff-table">
                            <tr class="diff-row-add">
                                <td class="line-num">{{ new_line.val }}</td>
                                <td class="diff-content-cell">
                                    <div class="line-content">{{ item.content }}</div>
                                </td>
                            </tr>
                        </table>
                    {% elif item.type == "del" %}
                        {% set old_line.val = old_line.val + 1 %}
                        <table class="diff-table">
                            <tr class="diff-row-del">
                                <td class="line-num">{{ old_line.val }}</td>
                                <td class="diff-content-cell">
                                    <div class="line-content">{{ item.content }}</div>
                                </td>
                            </tr>
                        </table>
                    {% elif item.type == "ctx" %}
                        {% set old_line.val = old_line.val + 1 %}
                        {% set new_line.val = new_line.val + 1 %}
                        <table class="diff-table">
                            <tr class="diff-row-ctx">
                                <td class="line-num">{{ old_line.val }}</td>
                                <td class="diff-content-cell">
                                    <div class="line-content">{{ item.content }}</div>
                                </td>
                            </tr>
                        </table>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
        {% else %}
        <div class="evidence-annotated" style="background: #f6f8fa; border-color: #d0d7de;">
            <div class="evidence-annotated-title" style="color: #57606a;">无完整 diff 数据（首次爬取或 diff 为空）</div>
        </div>
        {% endif %}
    </div>

    <div class="report-footer">
        本报告由竞争情报监控系统自动生成 · {{ feed.published_at.strftime("%Y-%m-%d %H:%M") }}
    </div>
</body>
</html>

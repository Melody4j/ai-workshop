<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>竞品情报报告 - {{ feed.project.project_name }}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; color: #333; }
        h1 { color: #1a1a1a; border-bottom: 2px solid #4a90d9; padding-bottom: 10px; }
        h2 { color: #4a90d9; margin-top: 30px; }
        .meta { color: #888; font-size: 14px; margin-bottom: 20px; }
        .field { margin-bottom: 20px; }
        .field h2 { margin-bottom: 8px; }
        .field p { line-height: 1.6; white-space: pre-wrap; }
        .evidence { background: #f5f5f5; padding: 12px; border-radius: 4px; font-family: monospace; font-size: 13px; }
    </style>
</head>
<body>
    <h1>竞品情报报告</h1>
    <div class="meta">
        项目：{{ feed.project.project_name }} |
        时间：{{ feed.published_at.strftime("%Y-%m-%d %H:%M") }} |
        状态：{{ feed.job_status }}
    </div>

    <div class="field">
        <h2>变化摘要</h2>
        <p>{{ feed.change_summary }}</p>
    </div>

    <div class="field">
        <h2>战略意图</h2>
        <p>{{ feed.strategic_intent }}</p>
    </div>

    <div class="field">
        <h2>行动建议</h2>
        <p>{{ feed.action_suggestion }}</p>
    </div>

    <div class="field">
        <h2>证据 Diff</h2>
        <div class="evidence">{{ feed.evidence_diff }}</div>
    </div>
</body>
</html>

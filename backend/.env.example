# Django 核心配置
DJANGO_SECRET_KEY=dev-only-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
SITE_BASE_URL=http://localhost:5173

# 数据库（Postgres）
# 本地开发可使用 SQLite：sqlite:///backend/data/db.sqlite3
# 生产使用 Supabase/Vercel Postgres 连接字符串（非池化 URL）
DATABASE_URL=sqlite:///backend/data/db.sqlite3

# LLM 配置（OpenAI 兼容 API）
# 支持 OpenAI / DeepSeek / 通义 / Moonshot 等兼容接口
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Firecrawl 配置
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Inngest 配置
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vercel Blob 配置
BLOB_READ_WRITE_TOKEN=
